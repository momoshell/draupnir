# syntax=docker/dockerfile:1
#
# Containerized PDF intake service. Built separately from the core image so the
# PDF tooling (AGPL-or-commercial PyMuPDF, raster stack) is isolated from the
# lean core API/worker runtime. See ADR 0010.
FROM python:3.12-slim

COPY --from=ghcr.io/astral-sh/uv:0.11.8 /uv /uvx /bin/

ENV PATH="/srv/.venv/bin:$PATH"

# Raster OCR tooling (optional mode). Kept here, never in the core image.
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    tesseract-ocr \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /srv

# Optional dependency extras to install (e.g. "vector", "vector,raster").
# Defaults to the vector (PyMuPDF) stack; set to an empty string for base only.
ARG PDF_INTAKE_EXTRAS="vector"

COPY pyproject.toml ./
COPY app/ ./app/

RUN uv venv /srv/.venv \
    && uv pip install --python /srv/.venv ".[${PDF_INTAKE_EXTRAS}]"

RUN useradd -m -u 1000 svcuser && chown -R svcuser:svcuser /srv
USER svcuser

EXPOSE 8100

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD curl -f http://localhost:8100/health || exit 1

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8100"]
