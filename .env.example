# =============================================================================
# Draupnir — Environment Variables Template
# =============================================================================
# Copy this file to .env and adjust values for your local development setup.
# =============================================================================

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------
# SQLAlchemy connection URL for PostgreSQL
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/draupnir

# ---------------------------------------------------------------------------
# Message Broker Configuration
# ---------------------------------------------------------------------------
# Celery broker URL for RabbitMQ
# Format: amqp://<user>:<password>@<host>:<port>/<vhost>
BROKER_URL=amqp://guest:guest@rabbitmq:5672//

# ---------------------------------------------------------------------------
# Application Settings
# ---------------------------------------------------------------------------
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Maximum upload file size in megabytes
MAX_UPLOAD_MB=50

# Service name for structured logging
SERVICE_NAME=draupnir

# ---------------------------------------------------------------------------
# PostgreSQL Container Configuration
# ---------------------------------------------------------------------------
# These are used by docker-compose.yml to configure the postgres service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=draupnir
