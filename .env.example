# =============================================================================
# Draupnir — Local Development Environment
# =============================================================================
# This stack is for local development only. Do not commit real secrets.
# =============================================================================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/draupnir

# Message broker
BROKER_URL=amqp://guest:guest@localhost:5672//

# Logging
LOG_LEVEL=info

# Upload limits
MAX_UPLOAD_MB=50
STORAGE_LOCAL_ROOT=var/uploads
# Backward-compatible alias still accepted: UPLOAD_STORAGE_ROOT=var/uploads

# Service identity
SERVICE_NAME=draupnir

# Postgres container (for docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=draupnir

# ---------------------------------------------------------------------------
# Optional: override host-exposed ports when defaults collide with local
# services (e.g. you already have Postgres on 5432). Postgres/RabbitMQ/Flower
# can still be bound loopback-only where applicable.
# ---------------------------------------------------------------------------
# API_HOST_PORT=8000
# POSTGRES_HOST_PORT=5432
# RABBITMQ_HOST_PORT=5672
# RABBITMQ_MGMT_HOST_PORT=15672
# FLOWER_HOST_PORT=5555
